{
  "name": "@layers/amba-functions",
  "version": "0.1.1",
  "description": "The SDK Cloudflare Workers import to build amba functions. Provides defineFunction + a typed ctx (auth, collections, AI, events, storage, email, queue, fan-out, secrets).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsdown": "^0.12.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/layers/amba-functions.git"
  },
  "bugs": {
    "url": "https://github.com/layers/amba-functions/issues"
  },
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
